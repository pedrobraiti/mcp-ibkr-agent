# Interactive Brokers - Client Portal API (CPAPI / Web API REST)
# Auth: ONLY via the Client Portal Gateway + a manual browser login (no OAuth for retail).
# Use a DEDICATED username for the bot (one brokerage session per username — TWS/mobile drop it).
IBKR_API_BASE_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
# Label only — does NOT choose the account. Real money depends on which account the
# gateway is logged into; the ground truth is IBKR's isPaper (see account_type from
# session_status). Keep it honest so logs/intent match reality.
IBKR_TRADING_MODE=paper

# Trading / safety
TRADING_ALLOW_LIVE=false
TRADING_DRY_RUN=true
# Allow a SELL bigger than the position you hold (opening a short). Off by default.
TRADING_ALLOW_SHORT=false
MAX_ORDER_VALUE=100.0
# Cumulative spend cap across all buys in a day (leave empty for no daily cap).
MAX_DAILY_VALUE=
# Reject an identical order (symbol/side/size) placed within this window. 0 = off.
DUPLICATE_WINDOW_SECONDS=5
# Comma-separated tickers. Allowlist set = only those tradable; denylist always blocked.
SYMBOL_ALLOWLIST=
SYMBOL_DENYLIST=

# Audit log (local JSONL, gitignored)
TRADE_JOURNAL_PATH=logs/trades.jsonl

# Optional webhook (ntfy/Discord/generic) POSTed when the session needs reauth.
REAUTH_WEBHOOK_URL=

# Session (keep-alive)
TICKLE_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15

# Market hours (fractional orders only execute during RTH)
MARKET_TIMEZONE=America/New_York
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# =====================================================================================
# Crypto server (CCXT) — a SEPARATE MCP process from the IBKR one. Auth is just an API
# key (no gateway/browser/tickle), market is 24/7, spot-only by default.
# =====================================================================================
CRYPTO_EXCHANGE=binance          # binance | bybit | okx | mercadobitcoin | ...
CRYPTO_API_KEY=
CRYPTO_API_SECRET=
CRYPTO_API_PASSWORD=             # only some exchanges (okx, kucoin) require a passphrase
# sandbox = exchange testnet (paper-first, free keys); live = REAL money.
CRYPTO_TRADING_MODE=sandbox
# Default quote currency for symbols given without one (e.g. "BTC" -> BTC/USDT).
CRYPTO_QUOTE_CCY=USDT
# Hard spot-only lock; when true it also allows selling beyond holdings (shorting).
CRYPTO_ALLOW_MARGIN=false
# Venue-specific real-money arm — SEPARATE from TRADING_ALLOW_LIVE so arming IBKR does
# NOT arm crypto. Live crypto needs CRYPTO_TRADING_MODE=live AND CRYPTO_ALLOW_LIVE=true.
CRYPTO_ALLOW_LIVE=false
# Venue-specific dry-run (validate but don't send). Independent of TRADING_DRY_RUN, so crypto
# stays safe-by-default even when IBKR's dry-run is off.
CRYPTO_DRY_RUN=true
# Separate audit log so crypto and IBKR daily-caps / duplicate-guards don't mix venues.
CRYPTO_TRADE_JOURNAL_PATH=logs/crypto_trades.jsonl
# Shared POLICY limits (MAX_ORDER_VALUE, MAX_DAILY_VALUE, DUPLICATE_WINDOW_SECONDS,
# SYMBOL_ALLOWLIST/DENYLIST) above apply to BOTH servers — MAX_ORDER_VALUE is in the venue's
# quote currency (e.g. USDT for crypto). The live/dry-run arms are per-venue (CRYPTO_* above).

# Logging
LOG_LEVEL=INFO
