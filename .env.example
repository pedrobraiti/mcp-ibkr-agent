# Interactive Brokers - Client Portal API (CPAPI / Web API REST)
# Auth: SÓ via Client Portal Gateway + login manual no navegador (OAuth não é liberado p/ varejo).
# Use um USERNAME DEDICADO ao bot (1 brokerage session por username — TWS/mobile derrubam a sessão).
IBKR_API_BASE_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
IBKR_TRADING_MODE=paper

# Trading / segurança
TRADING_ALLOW_LIVE=false
TRADING_DRY_RUN=true
MAX_ORDER_VALUE=100.0

# Sessão (keep-alive)
TICKLE_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15

# Market hours (fracionário só executa em RTH)
MARKET_TIMEZONE=America/New_York
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# Logging
LOG_LEVEL=INFO
