# Interactive Brokers - Client Portal API (CPAPI / Web API REST)
IBKR_API_BASE_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
IBKR_TRADING_MODE=paper

# Auth OAuth (alvo headless) - preencher quando o acesso OAuth estiver liberado
IBKR_OAUTH_CONSUMER_KEY=
IBKR_OAUTH_ACCESS_TOKEN=
IBKR_OAUTH_ACCESS_TOKEN_SECRET=

# Trading / segurança
TRADING_ALLOW_LIVE=false
TRADING_DRY_RUN=true
MAX_ORDER_VALUE=100.0

# Market hours
MARKET_TIMEZONE=America/New_York
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# Logging
LOG_LEVEL=INFO
